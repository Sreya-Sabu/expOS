[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 9] = 8; //changing mode flag to syscall no

alias userSP R0;
userSP = SP;

[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13] = SP;
SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] *16 + 11] * 512 - 1;

multipush (R0);

R1 = 1;
call MOD_1;
alias newPID R2;
newPID = R0;

multipop(R0);

if(newPID == -1) then 
    [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 9] = 0;
    [[PTBR + 2 * ((userSP - 1)/512)] * 512 + (userSP - 1) % 512] = -1; // storing -1 as return value in user stack
    SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13]; // switch back to user mode

else
    // when heap pages for parent are not allocated
    if([PTBR + 4] == -1) then
        multipush(R0,R1,R2);

        R1 = 1;
        call MOD_2;
        [PTBR + 4] = R0;
        [PTBR + 5] = "0110";
        R1 = 1;
        call MOD_2;
        [PTBR + 6] = R0;
        [PTBR + 7] = "0110";

        multipop(R0,R1,R2);
    endif;

    alias newPTBR R3;
    newPTBR = PAGE_TABLE_BASE + 20 * newPID;

    // Allocating Stack
    multipush(R0, R1, R2, R3);

    R1 = 1;
    call MOD_2;
    [newPTBR + 16] = R0;
    [newPTBR + 17] = "0110";
    R1 = 1;
    call MOD_2;
    [newPTBR + 18] = R0;
    [newPTBR + 19] = "0110";

    multipop(R0, R1, R2, R3);

    //setting up child's PROCESS_TABLE
    [PROCESS_TABLE + newPID * 16 + 3] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 3]; //USERID
    [PROCESS_TABLE + newPID * 16 + 6] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 6]; //SWAP FLAG
    [PROCESS_TABLE + newPID * 16 + 10] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 10]; //USER SWAP AREA STATUS
    [PROCESS_TABLE + newPID * 16 + 7] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 7]; //INODE INDEX
    [PROCESS_TABLE + newPID * 16 + 13] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13]; // UPTR (contents in both user stack are gonna be the same)

    [PROCESS_TABLE + newPID * 16 + 9] = 0; // mode flag
    [PROCESS_TABLE + newPID * 16 + 12] = 0; // kptr
    [PROCESS_TABLE + newPID * 16 + 0] = 0; // tick
    [PROCESS_TABLE + newPID * 16 + 2] = [SYSTEM_STATUS_TABLE + 1]; // ppid
    [PROCESS_TABLE + newPID * 16 + 4] = CREATED; //state

    multipush(R0, R1, R2, R3);

    R1 = 1;
    call MEMORY_MANAGER;
    R5 = R0;

    multipop(R0, R1, R2, R3);

    [PROCESS_TABLE + newPID * 16 + 11] = R5; // user area page

    // initialization per process resourse table child
    alias i R4;
    i = 512 - 16;
    while (i < 512) do
        [[PROCESS_TABLE + newPID * 16 + 11] * 512 + i] = [[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 11] * 512 + i];
        [[PROCESS_TABLE + newPID * 16 + 11] * 512 + i + 1] = [[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 11] * 512 + i + 1];
        if ([[PROCESS_TABLE + (newPID*16 + 11)]*512 + i] == 1) then 
            [SEMAPHORE_TABLE + [[PROCESS_TABLE + (newPID*16) + 11]*512 + i + 1]*4 + 1] = [SEMAPHORE_TABLE + [[PROCESS_TABLE + (newPID*16) + 11]*512 + i + 1]*4 + 1] + 1;
        endif;
        i = i + 2;
    endwhile;

    // disk map table for child
    i = 0;
    while (i < 10) do
        [DISK_MAP_TABLE + 10 * newPID + i] = [DISK_MAP_TABLE + [SYSTEM_STATUS_TABLE + 1] * 10 + i];
        i = i + 1;
    endwhile;

    // setting up page table

    i = 0;
    while(i < 16) do
    [newPTBR + i] = [PTBR + i];
    [newPTBR + i + 1] = [PTBR + i + 1];
    if([newPTBR + i] != -1) then
        [MEMORY_FREE_LIST + [newPTBR + i]] = [MEMORY_FREE_LIST + [newPTBR + i]] + 1;
    endif;
    i = i + 2;
    endwhile;

    // copy the user stack contents;
    alias oldstack R5;
    alias newstack R6;

    oldstack = [PTBR + 16];
    newstack = [newPTBR + 16];

    i = 0;
    while(i < 512) do
        [newstack * 512 + i] = [oldstack * 512 + i];
        i = i + 1;
    endwhile;

    oldstack = [PTBR + 18];
    newstack = [newPTBR + 18];

    i = 0;
    while (i < 512) do
        [newstack * 512 + i] = [oldstack * 512 + i];
        i = i + 1;
    endwhile;


    [[PROCESS_TABLE + newPID * 16 + 11] * 512] = BP;
    [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 9] = 0;

    // setting up return values for parent(pid of child) & child(0);



    [[PTBR + 2 * ((userSP - 1) / 512)] * 512 + (userSP - 1) % 512] = newPID;
    [[newPTBR + 2 * ((userSP - 1) / 512)] * 512 + (userSP - 1) % 512] = 0;

    SP = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1] * 16 + 13];
    
endif;
ireturn;